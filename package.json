{
  "name": "har-to-openapi",
  "version": "0.0.0-development",
  "license": "MIT",
  "author": "Jonluca DeCaro <hartoopenapi@jonlu.ca>",
  "description": "Convert a HAR object to an OpenAPI object",
  "types": "dist/index.d.ts",
  "bin": "./bin/har-to-openapi.cjs",
  "files": [
    "dist",
    "src",
    "package.json",
    "tsconfig.json"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "keywords": [
    "har",
    "openapi",
    "json",
    "api",
    "converter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonluca/har-to-openapi.git"
  },
  "bugs": {
    "url": "https://github.com/jonluca/har-to-openapi/issues"
  },
  "homepage": "https://github.com/jonluca/har-to-openapi",
  "scripts": {
    "prepublishOnly": "yarn build",
    "lint": "eslint src",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --write \"**/*.+(js|jsx|ts|tsx|har|json|css|md)\"",
    "test": "vitest --coverage",
    "test:update": "vitest -u",
    "test:watch": "vitest -w"
  },
  "dependencies": {
    "@loopback/openapi-v3-types": "^1.2.1",
    "@openapi-contrib/json-schema-to-openapi-schema": "^4.3.2",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "quicktype-core": "^23.2.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/eslint": "9.6.1",
    "@types/har-format": "^1.2.16",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/sort-json": "^2.0.3",
    "@vitest/coverage-v8": "^4.1.2",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "openapi-schema-validator": "^12.1.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": [
      "eslint --cache --fix"
    ],
    "**/*.{js,ts,jsx,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "packageManager": "yarn@4.13.0"
}
