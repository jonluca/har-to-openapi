{
  "name": "har-to-openapi",
  "version": "0.0.0-development",
  "type": "module",
  "license": "MIT",
  "author": "JonLuca DeCaro <hartoopenapi@jonlu.ca>",
  "description": "Convert a HAR object to an OpenAPI object",
  "types": "dist/index.d.ts",
  "bin": "./bin/har-to-openapi.cjs",
  "files": [
    "dist",
    "bin",
    "src",
    "package.json",
    "tsconfig.json"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "har",
    "openapi",
    "json",
    "api",
    "converter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonluca/har-to-openapi.git"
  },
  "bugs": {
    "url": "https://github.com/jonluca/har-to-openapi/issues"
  },
  "homepage": "https://github.com/jonluca/har-to-openapi",
  "scripts": {
    "prepublishOnly": "yarn build",
    "lint": "oxlint src",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "oxfmt --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:update": "vitest run -u",
    "test:watch": "vitest -w"
  },
  "dependencies": {
    "@loopback/openapi-v3-types": "^1.2.1",
    "@openapi-contrib/json-schema-to-openapi-schema": "^4.3.2",
    "js-yaml": "^4.1.1",
    "lodash-es": "^4.17.23",
    "quicktype-core": "^23.2.6"
  },
  "devDependencies": {
    "@types/har-format": "^1.2.16",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/sort-json": "^2.0.3",
    "@vitest/coverage-v8": "^4.1.2",
    "c8": "^11.0.0",
    "lint-staged": "^16.4.0",
    "openapi-schema-validator": "^12.1.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "rimraf": "^6.1.3",
    "typescript": "6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": [
      "oxlint --fix"
    ],
    "**/*.{js,ts,jsx,tsx,json,css,md}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "packageManager": "yarn@4.13.0"
}
